# Database Configuration (PostgreSQL)
DB_URL=jdbc:postgresql://localhost:5432/agriconnect
DB_USERNAME=postgres
DB_PASSWORD=your_password

# Server / Environment
PORT=8080
SPRING_PROFILES_ACTIVE=dev

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_min_256_bits
JWT_EXPIRATION=604800000

# Database Pool / JPA
DB_CONNECTION_TIMEOUT=30000
DB_MAX_POOL_SIZE=10
DB_MIN_IDLE=5
JPA_DDL_AUTO=validate
JPA_SHOW_SQL=false

# Flyway (Production-grade migration control)
FLYWAY_ENABLED=true
FLYWAY_BASELINE_ON_MIGRATE=true
FLYWAY_BASELINE_VERSION=0
FLYWAY_AUTO_REPAIR_ON_VALIDATION_ERROR=true

# Upload Limits
MAX_FILE_SIZE=25MB
MAX_REQUEST_SIZE=60MB

# Twilio Configuration
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=your_phone_number

# Email Configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password

# Eureka Configuration
EUREKA_SERVER_URL=http://localhost:8761/eureka/

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:5000,http://localhost:5174,http://localhost:1819

# Feature Flags
FEATURE_MOBILE_VERIFICATION_ENABLED=true
# Set to true ONLY when Kafka + Schema Registry are running locally
FEATURE_KAFKA_ENABLED=false

# ── Caching Configuration ─────────────────────────────────────────────────────
# Local Development: Enable Redis caching
CACHE_LOCAL_ENABLED=true

# ── Redis Configuration (Local Development with Docker Compose) ────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Production: Enable Valkey caching (set in production environment only)
# CACHE_PROD_ENABLED=true

# ── Valkey Configuration (Production - AWS ElastiCache) ────────────────────────
# Set these ONLY in production environment (not in .env file)
# VALKEY_URL=rediss://your-valkey-cluster.cache.amazonaws.com:6379
# VALKEY_PASSWORD=your-valkey-password
# CACHE_PROD_ENABLED=true
