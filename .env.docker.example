# ==========================================
# Root .env for Docker Compose
# ==========================================
# Only infra-level variables live here.
# All service-specific secrets (Twilio, JWT, Razorpay, etc.)
# are loaded directly from each service's own .env file
# via the env_file directive in docker-compose.yml.

# Docker Hub username (used in image names for push/pull)
DOCKER_USERNAME=darktechie

# Image tag (default: latest)
TAG=latest

# MySQL root password (must match DB_PASSWORD in each service .env)
MYSQL_ROOT_PASSWORD=Vandit@2512
