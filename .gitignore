
# ========================================
# Environment & Configuration Files
# ========================================
# IMPORTANT: Never commit .env files containing sensitive data!

# Root level env files
.env
.env.local
.env.development
.env.test
.env.production
.env.*.local

# Service-specific env files (explicit paths)
Main-Backend/.env
Main-Backend/.env.local
Main-Backend/.env.*
Contract-Farming-App/.env
Contract-Farming-App/.env.local
Contract-Farming-App/.env.*
Market-Access-App/.env
Market-Access-App/.env.local
Market-Access-App/.env.*
Smart-Advisory-App/.env
Smart-Advisory-App/.env.local
Smart-Advisory-App/.env.*
Generate-Agreement-App/.env
Generate-Agreement-App/.env.local
Generate-Agreement-App/.env.*
Eureka-Main-Server/.env
Eureka-Main-Server/.env.local
Eureka-Main-Server/.env.*

# Pattern matching for any .env files (recursive)
**/.env
**/.env.local
**/.env.*.local

# Keep .env.example files (these should be committed)
!.env.example
!**/.env.example

