.classpath
.project
.settings/
.metadata/

# VS Code
.vscode/
*.code-workspace

# NetBeans
nbproject/
nbbuild/
dist/
nbdist/

# ========================================
# Build & Compilation Files
# ========================================
# Maven
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# Gradle
.gradle/
build/
!gradle-wrapper.jar

