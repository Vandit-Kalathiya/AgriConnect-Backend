# Database Configuration (PostgreSQL)
DB_URL=jdbc:postgresql://localhost:5432/agriconnect
DB_USERNAME=postgres
DB_PASSWORD=your_password

# Server Configuration
PORT=2527
SPRING_PROFILES_ACTIVE=dev

# Database Pool / JPA
DB_CONNECTION_TIMEOUT=30000
DB_MAX_POOL_SIZE=10
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false
FLYWAY_ENABLED=true
FLYWAY_BASELINE_ON_MIGRATE=true
FLYWAY_BASELINE_VERSION=0
FLYWAY_AUTO_REPAIR_ON_VALIDATION_ERROR=true

# File Upload Configuration
MAX_FILE_SIZE=10MB
MAX_REQUEST_SIZE=10MB

# Eureka Configuration
EUREKA_SERVER_URL=http://localhost:8761/eureka/

# Logging
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=DEBUG

# AI Core Configuration
AI_ENABLED=true
AI_SCHEMA_VERSION=1.0.0
AI_PROVIDER=groq
AI_MODEL=llama-3.3-70b-versatile
AI_GROQ_API_KEY=your_groq_api_key_here
AI_GROQ_BASE_URL=https://api.groq.com
AI_TIMEOUT_MS=12000
AI_RETRIES=2
AI_CHAT_HISTORY_LIMIT=12
AI_CACHE_TTL_SECONDS=120
AI_CHAT_PUBLIC_PER_MINUTE=20

# AI Persistence Configuration
AI_PERSISTENCE_ENABLED=true
AI_PERSISTENCE_CONTEXT_WINDOW=12
AI_PERSISTENCE_RETENTION_DAYS=30
AI_PERSISTENCE_MAX_CONTENT_LENGTH=3900
AI_PERSISTENCE_CLEANUP_ENABLED=true
AI_PERSISTENCE_CLEANUP_BATCH_SIZE=1000
AI_PERSISTENCE_CLEANUP_MAX_BATCHES=5
AI_PERSISTENCE_CLEANUP_CRON=0 0 3 * * *
