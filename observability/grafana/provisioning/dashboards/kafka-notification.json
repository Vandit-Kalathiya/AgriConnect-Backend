{
  "__inputs": [],
  "__requires": [
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat",       "name": "Stat",        "version": "" },
    { "type": "panel", "id": "bargauge",   "name": "Bar gauge",   "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "AgriConnect Kafka Notification Service — throughput, lag, channel delivery, DLQ, and latency",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Throughput",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum by (channel, status) (rate(notification_dispatch_total_total[1m]) * 60)",
          "legendFormat": "{{channel}} / {{status}}",
          "refId": "A"
        }
      ],
      "title": "Notifications Dispatched / min (by channel & status)",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto" },
      "targets": [
        {
          "expr": "sum(increase(notification_dlq_total_total[5m]))",
          "legendFormat": "DLQ events (5m)",
          "refId": "A"
        }
      ],
      "title": "DLQ Events (5m)",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "kafka_consumer_records_lag_max{job=\"notification-service\"}",
          "legendFormat": "Lag — {{topic}} p{{partition}}",
          "refId": "A"
        }
      ],
      "title": "Consumer Lag (max per partition)",
      "type": "bargauge"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "Latency",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 4,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (channel, le) (rate(notification_dispatch_duration_seconds_bucket[1m])))",
          "legendFormat": "P50 {{channel}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (channel, le) (rate(notification_dispatch_duration_seconds_bucket[1m])))",
          "legendFormat": "P95 {{channel}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (channel, le) (rate(notification_dispatch_duration_seconds_bucket[1m])))",
          "legendFormat": "P99 {{channel}}",
          "refId": "C"
        }
      ],
      "title": "Dispatch Latency P50 / P95 / P99 by channel",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 102,
      "title": "JVM Health",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "id": 5,
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{job=\"notification-service\",area=\"heap\"}",
          "legendFormat": "Heap Used",
          "refId": "A"
        },
        {
          "expr": "jvm_memory_max_bytes{job=\"notification-service\",area=\"heap\"}",
          "legendFormat": "Heap Max",
          "refId": "B"
        }
      ],
      "title": "Notification-Service JVM Heap",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["kafka", "notifications", "agriconnect"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "AgriConnect — Kafka Notification System",
  "uid": "agriconnect-notifications",
  "version": 1
}
